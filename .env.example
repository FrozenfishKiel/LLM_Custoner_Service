# Application
APP_ENV=development
APP_SECRET_KEY=replace-with-a-random-secret
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
# Local legacy topology only; production must use a dedicated non-root account.
MYSQL_DATABASE=ecs
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-a-strong-password
MIGRATION_EXPECTED_TARGET=127.0.0.1:3306/ecs

# Redis and Neo4j
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=604800
SESSION_REFRESH_THRESHOLD_SECONDS=86400
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-strong-password

# LLM providers
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_USE_TLS=false
