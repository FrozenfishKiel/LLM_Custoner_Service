# Application
APP_ENV=development
APP_SECRET_KEY=replace-with-a-random-secret
PUBLIC_BASE_URL=http://localhost:8000
AUTH_PUBLIC_BASE_URL=http://localhost:8000/auth
ALLOWED_ORIGINS=http://localhost:8000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
# Local legacy topology only; production must use a dedicated non-root account.
MYSQL_DATABASE=ecs
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-a-strong-password
MIGRATION_EXPECTED_TARGET=127.0.0.1:3306/ecs

# Redis and Neo4j
# 本地默认使用 DB 15，避免和用户已有 Redis 数据混在一起；生产环境请使用独立 Redis 实例或独立 DB。
REDIS_URL=redis://localhost:6379/15
SESSION_TTL_SECONDS=604800
SESSION_REFRESH_THRESHOLD_SECONDS=86400
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-strong-password

# LLM providers
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_USE_TLS=false

# Production FastAPI wiring
# 生产启动入口可调用 atguigu_ai.api.create_production_app()。
# PRODUCTION_CHAT_ENABLED=true 时会加载真实 Agent 并挂载 /api/chat/*。
PRODUCTION_CHAT_ENABLED=true
PRODUCTION_AGENT_PATH=ecs_demo
PRODUCTION_ENABLE_INSPECT=false

# Production operations
# /health/live 只表示进程存活。
# /health/ready 检查 auth/chat/agent/rate limiter 是否完成装配。
# /internal/metrics 暴露最小文本指标；生产环境必须通过反向代理或网络策略限制访问。
